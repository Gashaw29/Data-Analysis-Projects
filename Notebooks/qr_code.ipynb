    "import qrcode\n",
    "\n",
    "# Define the link or text you want to embed\n",
    "data = \"https://ee.kobotoolbox.org/x/GafFxoRh\"\n",
    "\n",
    "# Generate the QR code image\n",
    "img = qrcode.make(data)\n",
    "\n",
    "# Save the image to your computer\n",
    "img.save(\"Client_Sat_qr.png\")\n",
    "print(\"Basic QR Code saved successfully!\")\n",
    "\n",
    "\n",
    "\n"
   ]
